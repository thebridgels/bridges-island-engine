# Copy this file to .env.local and fill in the values from your Supabase
# project: Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Architect Chat (server-only — never NEXT_PUBLIC_*). The API key is a
# model-provider credential, not a database credential: it grants zero rows.
# All chat context is fetched through the requesting user's RLS session.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional. Defaults to a low-cost Claude model for alpha testing; an
# architect's stored model_name (when set and valid) wins over this.
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5
